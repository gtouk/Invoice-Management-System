.env
backend/.env
frontend/.env
.env.prod
.env.production
.env.production.local
frontend/.env.production.local
backend/.env.production.local

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build / cache
dist/
build/
.DS_Store
*.log
npm-debug.log*

# Uploaded / generated files (keep directory placeholders)
storage/invoices/**
!storage/invoices/.gitkeep
storage/bank-statements/**
!storage/bank-statements/.gitkeep
storage/company/**
!storage/company/.gitkeep
storage/private/**
!storage/private/.gitkeep
storage/exports/**
!storage/exports/.gitkeep
storage/ocr-temp/**
!storage/ocr-temp/.gitkeep

# IDE
.idea/
.vscode/

# Local DB dumps / backups (keep out of Git)
backups/*
!backups/.gitkeep
*.sql.bak
*.dump
