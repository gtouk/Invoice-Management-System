# Backend-only example. Prefer the root `.env` / `.env.prod` with Docker Compose.

NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:postgres@localhost:5435/invoice_system

JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

STORAGE_ROOT=/app/storage

# local (default) | supabase
STORAGE_PROVIDER=local
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=   # NEVER expose to frontend
# SUPABASE_STORAGE_BUCKET=invoice-files
# Company logos use the same provider; public URL = /api/public/companies/:id/logo

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_FROM=no-reply@example.com
