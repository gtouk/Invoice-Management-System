# SMTP / Mailtrap (required for invoice emails)
# Replace placeholders with credentials from https://mailtrap.io (Email Testing → SMTP Settings)

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_username
SMTP_PASSWORD=your_mailtrap_password
SMTP_FROM=no-reply@yourdomain.com

# Optional aliases also supported by the backend:
# SMTP_PASS=...
# SMTP_FROM_EMAIL=...
# SMTP_FROM_NAME=...
