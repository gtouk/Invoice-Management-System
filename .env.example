# =============================================================================
# Invoice Management System — environment example (NO real secrets)
# Copy to `.env` for local Docker Compose, or use `.env.prod.example` for prod.
# =============================================================================

NODE_ENV=development
PORT=5000

# Postgres (used by docker-compose.yml)
POSTGRES_DB=invoice_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5435

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/invoice_system

# JWT — generate long random values before any public/beta deploy
# Aliases accepted: JWT_SECRET (fallback), JWT_EXPIRES_IN
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS / frontend origin (required in production — no wildcard)
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
# Optional comma-separated list:
# CORS_ORIGINS=http://localhost:5173,https://app.example.com

# Rate limits (optional overrides)
# RATE_LIMIT_API_MAX=300
# RATE_LIMIT_AUTH_MAX=10

# Storage root inside the backend container / process
STORAGE_ROOT=/app/storage

# Storage provider: local (Docker/dev) | supabase (free beta on Render)
STORAGE_PROVIDER=local
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace_me_backend_only_never_in_frontend
# SUPABASE_STORAGE_BUCKET=invoice-files
# PDFs, bank statements AND company logos use this provider.
# Logos are served via GET /api/public/companies/:companyId/logo (bucket can stay private).

# SMTP / Mailtrap
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_PASSWORD=replace_me
SMTP_FROM=no-reply@example.com

# Frontend API URL (Vite)
# Local:  http://localhost:5000/api
# Prod:   https://api.example.com/api  OR  /api  behind same-origin nginx
VITE_API_URL=http://localhost:5000/api

# pgAdmin (local only)
PGADMIN_DEFAULT_EMAIL=admin@invoice.local
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050
BACKEND_PORT=5000
FRONTEND_PORT=5173
