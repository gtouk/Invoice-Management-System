# =============================================================================
# Production / private beta — copy to `.env.prod` (DO NOT commit real secrets)
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# =============================================================================

NODE_ENV=production

# --- Postgres ---
POSTGRES_DB=invoice_db
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=replace_with_strong_db_password

# --- Backend ---
PORT=5000
DATABASE_URL=postgresql://invoice_user:replace_with_strong_db_password@postgres:5432/invoice_db

JWT_ACCESS_SECRET=replace_with_long_random_access_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=https://app.example.com
CORS_ORIGIN=https://app.example.com

STORAGE_ROOT=/app/storage

# local for Docker VPS | supabase for free Render beta (see docs/FREE_DEPLOYMENT.md)
STORAGE_PROVIDER=local
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=invoice-files
# Logos: public/companies/{id}/logo.* served by GET /api/public/companies/:id/logo

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=replace_me
SMTP_PASS=replace_me
SMTP_FROM=no-reply@example.com

# Frontend build-time API base (same-origin nginx recommended)
# Same host via reverse proxy: /api
# Separate API subdomain: https://api.example.com/api
VITE_API_URL=/api

# Optional rate-limit overrides
# RATE_LIMIT_API_MAX=300
# RATE_LIMIT_AUTH_MAX=10
